# API Configuration
# For Docker deployment, use the container name or external URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# For production with external domain
# NEXT_PUBLIC_API_URL=https://your-domain.com

# Optional: External database (Supabase, Vercel Postgres, etc.)
# DATABASE_URL=postgresql://...
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_ANON_KEY=xxx

# Node environment (set automatically by Docker)
# NODE_ENV=production
